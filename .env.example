# 飞书自建应用凭据(仅本地使用, 不入库)
# 复制本文件为 .env 并填入真实值:  cp .env.example .env
# 从 Cloudflare Pages 项目 Settings -> Environment variables 取同名变量的值
# 注意: app_secret 是 Secret 类型, 本地自己保管, 不要贴进聊天/截图/git

# 应用 App ID(明文, 与 Cloudflare 的 FEISHU_APP_ID 一致)
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx

# 应用 App Secret(Secret 类型, 与 Cloudflare 的 FEISHU_APP_SECRET 一致)
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 表格 token(与 Cloudflare 的 FEISHU_SHEET_TOKEN 一致)
# 即表格 URL 里 /sheets/ 后面那段
FEISHU_SHEET_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxx

# 选填: 指定子表名(表格里那个 tab 的名字, 如 "仙人森林产品库")
# 不填则自动用第一个子表
FEISHU_SHEET_NAME=

# 选填: API 域名(国内飞书默认 open.feishu.cn; 海外 Lark 用 open.larksuite.com)
FEISHU_DOMAIN=open.feishu.cn
